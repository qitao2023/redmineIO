# Redmine 日报工具配置文件
# 复制为 config.yaml 并填入实际值
# 注意：config.yaml 包含敏感信息，请勿提交到版本控制系统

# Redmine 服务器地址
redmine_url: "https://redmine.your-company.com"

# API 访问密钥（推荐使用环境变量 REDMINE_API_KEY 替代）
# 获取方式：Redmine → 我的账号 → API 访问键 → 显示
api_key: ""

# 时区（默认 Asia/Shanghai）
timezone: "Asia/Shanghai"

# 日报输出目录（默认 ./reports）
output_dir: "./reports"

# SSL 验证（内网自签名证书可设为 false）
requests_verify: true

# 请求超时秒数
requests_timeout: 30

# 限定查询的项目 ID 列表（可选）
# - 留空（默认）：自动从 Redmine membership API 获取当前用户所属项目
# - 手动指定：只查询列表中的项目，例如 [17, 23, 45]
# 手动指定可以提速，适合 membership API 不可用或用户跨项目太多时进行限制
# project_ids: [17, 23]

# 跳过审核/复核（只查本人创建/经办的 Issue，大幅提速）
skip_review: false
